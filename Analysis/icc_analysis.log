. /*==============================================================================
>   SECTION 5 — CONDITIONAL ICC FOR THE PHILIPPINES  (via mixed + estat icc)
> 
>   After each mixed call, estat icc returns:
>     r(icc2)  = school-level ICC
>     r(se2)   = SE of school-level ICC (delta method)
> 
>   Variance explained at school level (VES):
>     VES = 1 − (mean σ²_u|X  /  mean σ²_u_null)
>   School-level variance σ²_u is still drawn from the mixed coefficient
>   [lns1_1_1]_cons since estat icc does not return it directly.
> 
>   Model A: School resources & size
>   Model B: Principal characteristics & community context
> ==============================================================================*/
. 
. di as txt _n(2) "========================================================"


========================================================

. di as txt        "  CONDITIONAL ICC — PHILIPPINES"
  CONDITIONAL ICC — PHILIPPINES

. di as txt        "========================================================"
========================================================

. 
. local cov_A "z_C_SCHSIZE z_STRATIO_PERM z_STRATIO_TEMP z_PCGIRLS_G5"

. local cov_B "i.C_GENDER z_C_AGE i.C_ISCED z_resou z_hinder z_comatpa z_comatst z_comattc z_studiss"

. 
. * Re-declare subjects (defensive; ensures the macro is set for this section)
. local subjects M R W

. 
. foreach subj of local subjects {
  2.     di as txt _n "  ===== Subject: `subj_lbl_`subj'' ====="
  3. 
.     *--- Null model (unconditional, PHL only) ---------------------------------*
.     scalar var_u_null_sum = 0
  4.     forvalues pv = 1/5 {
  5.         quietly mixed PV`pv'_`subj' [pw=wt_scaled] if CNT == "PHL" || schoolid:, mle
  6.         quietly estat icc
  7.         scalar icc_`pv' = r(icc2)
  8.         scalar se_`pv'  = r(se2)
  9.         scalar var_u_null_sum = var_u_null_sum + exp(2 * [lns1_1_1]_cons)
 10.     }
 11.     scalar var_u_null_avg = var_u_null_sum / 5
 12. 
.     scalar icc_bar = (icc_1 + icc_2 + icc_3 + icc_4 + icc_5) / 5
 13.     scalar V_W = ((se_1)^2 + (se_2)^2 + (se_3)^2 + (se_4)^2 + (se_5)^2) / 5
 14.     scalar V_B = ((icc_1 - icc_bar)^2 + (icc_2 - icc_bar)^2 + ///
>                   (icc_3 - icc_bar)^2 + (icc_4 - icc_bar)^2 + ///
>                   (icc_5 - icc_bar)^2) / 4
 15.     scalar se_comb = sqrt(V_W + 1.2 * V_B)
 16. 
.     di as txt _n "    Null model (unconditional):"
 17.     di as txt "      ICC = " %6.4f icc_bar "  SE = " %6.4f se_comb
 18. 
.     *--- Conditional models ---------------------------------------------------*
.     foreach spec in A B {
 19.         local covars "`cov_A'"
 20.         local desc   "Model A: School resources & size"
 21.         if "`spec'" == "B" {
 22.             local covars "`cov_B'"
 23.             local desc   "Model B: Principal characteristics & community"
 24.         }
 25. 
.         di as txt _n "    `desc':"
 26. 
.         scalar var_u_cond_sum = 0
 27.         local npv_ok = 0
 28. 
.         forvalues pv = 1/5 {
 29.             scalar icc_`pv' = .
 30.             scalar se_`pv'  = .
 31.             capture mixed PV`pv'_`subj' `covars' [pw=wt_scaled] ///
>                 if CNT == "PHL" || schoolid:, mle
 32.             if _rc di as txt "      PV`pv': model did not converge -- skipping"
 33.             if !_rc {
 34.                 quietly estat icc
 35.                 scalar icc_`pv' = r(icc2)
 36.                 scalar se_`pv'  = r(se2)
 37.                 scalar var_u_cond_sum = var_u_cond_sum + exp(2 * [lns1_1_1]_cons)
 38.                 local ++npv_ok
 39.             }
 40.         }
 41. 
.         * Rubin's rules (converged PVs only; cond() avoids nested if-block)
.         scalar icc_bar = 0
 42.         forvalues pv = 1/5 {
 43.             scalar icc_bar = icc_bar + cond(icc_`pv' == ., 0, icc_`pv')
 44.         }
 45.         scalar icc_bar = icc_bar / `npv_ok'
 46. 
.         scalar V_W = 0
 47.         scalar V_B = 0
 48.         forvalues pv = 1/5 {
 49.             scalar V_W = V_W + cond(icc_`pv' == ., 0, (se_`pv')^2)
 50.             scalar V_B = V_B + cond(icc_`pv' == ., 0, (icc_`pv' - icc_bar)^2)
 51.         }
 52.         scalar V_W = V_W / `npv_ok'
 53.         scalar V_B = V_B / (`npv_ok' - 1)
 54.         scalar se_comb = sqrt(V_W + (1 + 1/`npv_ok') * V_B)
 55. 
.         scalar var_u_cond_avg = var_u_cond_sum / `npv_ok'
 56.         scalar ves = 1 - (var_u_cond_avg / var_u_null_avg)
 57. 
.         di as txt "      ICC = " %6.4f icc_bar "  SE = " %6.4f se_comb ///
>                   "   95% CI: [" %6.4f (icc_bar - 1.96*se_comb) ///
>                   ", " %6.4f (icc_bar + 1.96*se_comb) "]"
 58.         di as txt "      Variance explained at school level (VES) = " %6.4f ves
 59.     }
 60. }

